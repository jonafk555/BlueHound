# BlueHound .env.example — copy to .env and fill in values
# NEVER commit .env to version control (it's in .gitignore)

# ── LLM Backend ───────────────────────────────────────────────
# Options: "ollama" | "openai" | "fallback" (tries ollama → openai → heuristic)
LLM_BACKEND=fallback

# Ollama (local, privacy-preserving)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (cloud)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────
# Restrict to localhost (127.0.0.1) for local use
# Set to 0.0.0.0 ONLY if running in a trusted internal network environment
BLUEHOUND_HOST=127.0.0.1
BLUEHOUND_PORT=8443

# ── Security ──────────────────────────────────────────────────
# Set a strong random API key to protect all endpoints.
# Leave blank for development-only open access (localhost only).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
BLUEHOUND_API_KEY=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8443,http://127.0.0.1:8443
